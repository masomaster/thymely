# Thymely environment variables
# Copy this file to `.env` and fill in values from your Supabase project
# (Supabase Dashboard -> Project Settings -> API).
#
# These use the EXPO_PUBLIC_ prefix so they are inlined into the client bundle.
# The anon key is safe to expose publicly; row-level security protects the data.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
